{
  "name": "ohos-playwright",
  "version": "0.2.6",
  "description": "Playwright adapter for OpenHarmony / ArkWeb via hdc + CDP",
  "license": "MIT",
  "author": "social4hyq",
  "homepage": "https://github.com/social4hyq/ohos-playwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/social4hyq/ohos-playwright.git"
  },
  "bugs": {
    "url": "https://github.com/social4hyq/ohos-playwright/issues"
  },
  "keywords": [
    "playwright",
    "openharmony",
    "ohos",
    "harmonyos",
    "arkweb",
    "e2e",
    "hdc",
    "cdp"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/fix-extensions.mjs",
    "test": "node --test src/*.test.mts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    "./fixture": "./dist/fixture.mjs",
    "./setup": "./dist/setup.mjs",
    "./teardown": "./dist/teardown.mjs",
    "./register": "./dist/register.mjs",
    "./loader": "./dist/loader.mjs",
    "./config": "./dist/config.mjs"
  },
  "bin": {
    "ohos-playwright": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "!dist/*.test.mjs"
  ],
  "peerDependencies": {
    "@playwright/test": ">=1.59.0"
  },
  "devDependencies": {
    "@playwright/test": ">=1.59.0",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
